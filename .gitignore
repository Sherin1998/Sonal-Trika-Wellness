# =============================================================================
# Vercel deployment — commit only:
#   package.json, package-lock.json, index.html, vite.config.ts, tsconfig.json
#   src/, public/ (including public/videos/**/*.mp4)
# =============================================================================

# Dependencies — omit the ENTIRE node_modules/ folder (never cherry-pick packages).
# Vercel recreates it via npm install from package-lock.json during build.
node_modules/

# Build output (generated by `vite build` on Vercel)
dist/
build/
server.js

# Secrets — configure in Vercel dashboard → Settings → Environment Variables
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test & coverage
coverage/

# TypeScript cache
*.tsbuildinfo

# Vite dev cache
.vite/

# Video assets — self-hosted in public/videos/ (must be committed for GitHub + Vercel)
# Ignore stray MP4s elsewhere; always track site videos under public/videos/
*.mp4
!public/videos/
!public/videos/**

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor / IDE
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~

# Cursor — local IDE config, rules, MCP (not used by Vercel)
.cursor/
agent-transcripts/
assets/

# Agent skills & AI tooling
.agents/
skills-lock.json

# AI Studio / local project metadata
metadata.json

# Internal docs (not required for production build)
docs/

# Misc local tooling
agent-tools/
terminals/
